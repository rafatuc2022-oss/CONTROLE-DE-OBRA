rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net - Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Master Gate (Relational Sync)
    function userOwnsObra(obraId) {
      return isSignedIn() && get(/databases/$(database)/documents/obras/$(obraId)).data.usuarioId == request.auth.uid;
    }

    // Entity Validations (Type Safety & Boundary Limits)
    function isValidUsuario(data) {
      return data.nome is string && data.nome.size() <= 200
        && data.email is string && data.email.size() <= 200;
    }

    function isValidObra(data) {
      return data.usuarioId is string && data.usuarioId.size() <= 128
        && data.nome is string && data.nome.size() <= 200
        && data.saldoInicial is number
        && data.saldoAtual is number;
    }

    function isValidEntrada(data) {
      return data.obraId is string && data.obraId.size() <= 128
        && data.valor is number && data.valor >= 0
        && data.data is string && data.data.size() <= 50
        && data.origem is string && data.origem.size() <= 200
        && data.descricao is string && data.descricao.size() <= 500;
    }

    function isValidSaida(data) {
      return data.obraId is string && data.obraId.size() <= 128
        && data.valor is number && data.valor >= 0
        && data.data is string && data.data.size() <= 50
        && data.categoria is string && data.categoria.size() <= 100
        && data.descricao is string && data.descricao.size() <= 500
        && (!('maoObraId' in data) || data.maoObraId is string)
        && (!('paymentId' in data) || data.paymentId is string);
    }

    function isValidMaoObra(data) {
      return data.obraId is string && data.obraId.size() <= 128
        && data.nome is string && data.nome.size() <= 200
        && data.funcao is string && data.funcao.size() <= 100
        && data.valor is number && data.valor >= 0
        && data.dataPagamento is string && data.dataPagamento.size() <= 50
        && data.formaPagamento is string && data.formaPagamento.size() <= 100
        && (!('valorContrato' in data) || data.valorContrato is number)
        && (!('pagamentos' in data) || data.pagamentos is list);
    }

    function isValidMaterial(data) {
      return data.obraId is string && data.obraId.size() <= 128
        && data.categoria is string && data.categoria.size() <= 100
        && data.nome is string && data.nome.size() <= 200
        && data.quantidade is number && data.quantidade >= 0
        && data.unidade is string && data.unidade.size() <= 50
        && data.valorUnitario is number && data.valorUnitario >= 0
        && data.valorTotal is number && data.valorTotal >= 0
        && data.loja is string && data.loja.size() <= 200
        && data.dataCompra is string && data.dataCompra.size() <= 50;
    }

    function isValidComparacaoPreco(data) {
      return data.usuarioId is string && data.usuarioId.size() <= 128
        && data.material is string && data.material.size() <= 200
        && data.loja is string && data.loja.size() <= 200
        && data.valor is number && data.valor >= 0
        && data.data is string && data.data.size() <= 50;
    }

    // Collection Security Rules
    match /usuarios/{userId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUsuario(incoming());
      allow update: if isOwner(userId) && isValidUsuario(incoming());
      allow delete: if isOwner(userId);
    }

    match /obras/{obraId} {
      allow create: if isSignedIn() && incoming().usuarioId == request.auth.uid && isValidObra(incoming());
      allow get: if isSignedIn() && existing().usuarioId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.usuarioId == request.auth.uid;
      allow update: if isSignedIn() && existing().usuarioId == request.auth.uid && incoming().usuarioId == request.auth.uid && isValidObra(incoming());
      allow delete: if isSignedIn() && existing().usuarioId == request.auth.uid;
    }

    match /entradas/{entradaId} {
      allow create: if isSignedIn() && userOwnsObra(incoming().obraId) && isValidEntrada(incoming());
      allow get: if isSignedIn() && userOwnsObra(existing().obraId);
      allow list: if isSignedIn();
      allow update: if isSignedIn() && userOwnsObra(existing().obraId) && userOwnsObra(incoming().obraId) && isValidEntrada(incoming());
      allow delete: if isSignedIn() && userOwnsObra(existing().obraId);
    }

    match /saidas/{saidaId} {
      allow create: if isSignedIn() && userOwnsObra(incoming().obraId) && isValidSaida(incoming());
      allow get: if isSignedIn() && userOwnsObra(existing().obraId);
      allow list: if isSignedIn();
      allow update: if isSignedIn() && userOwnsObra(existing().obraId) && userOwnsObra(incoming().obraId) && isValidSaida(incoming());
      allow delete: if isSignedIn() && userOwnsObra(existing().obraId);
    }

    match /maoObra/{maoObraId} {
      allow create: if isSignedIn() && userOwnsObra(incoming().obraId) && isValidMaoObra(incoming());
      allow get: if isSignedIn() && userOwnsObra(existing().obraId);
      allow list: if isSignedIn();
      allow update: if isSignedIn() && userOwnsObra(existing().obraId) && userOwnsObra(incoming().obraId) && isValidMaoObra(incoming());
      allow delete: if isSignedIn() && userOwnsObra(existing().obraId);
    }

    match /materiais/{materialId} {
      allow create: if isSignedIn() && userOwnsObra(incoming().obraId) && isValidMaterial(incoming());
      allow get: if isSignedIn() && userOwnsObra(existing().obraId);
      allow list: if isSignedIn();
      allow update: if isSignedIn() && userOwnsObra(existing().obraId) && userOwnsObra(incoming().obraId) && isValidMaterial(incoming());
      allow delete: if isSignedIn() && userOwnsObra(existing().obraId);
    }

    match /comparacaoPrecos/{comparacaoId} {
      allow create: if isSignedIn() && incoming().usuarioId == request.auth.uid && isValidComparacaoPreco(incoming());
      allow get: if isSignedIn() && existing().usuarioId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.usuarioId == request.auth.uid;
      allow update: if isSignedIn() && existing().usuarioId == request.auth.uid && incoming().usuarioId == request.auth.uid && isValidComparacaoPreco(incoming());
      allow delete: if isSignedIn() && existing().usuarioId == request.auth.uid;
    }
  }
}
